# Non-secret deployment settings
PROJECT_ID=your-gcp-project-id
REGION=us-central1
SERVICE_NAME=instagram-mcp
IG_USER_ID=your_instagram_business_account_id_here

# Local-only values used only with: bash deploy.sh --setup-secrets
# Never commit real values. Do not pass these via --set-env-vars.
IG_ACCESS_TOKEN=your_instagram_long_lived_token_here
MCP_API_KEY=generate_a_strong_random_api_key_here
